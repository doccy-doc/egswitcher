handle_unknown_session() {
    init_deps "file"
    guard_accounts_file
    local hkey="$1" target_name="${2:-}" new_name

    # Path A: Name provided. Check name is allowed.
    if [[ -n "$target_name" ]] && validate_account_name "$target_name" && ! account_exists "$target_name"; then
        new_name="$target_name"
    else
        [[ -n "$target_name" ]] && warn "Invalid account name: ${target_name}. Please try again."
        # Path B: No name provided (or validation failed). Prompt for one.
        while true; do
            read -rp "Account name: " new_name
            if ! validate_account_name "$new_name"; then
                warn "Invalid account name: ${new_name}. Please try again:"
            elif account_exists "$new_name"; then
                warn "The name ${new_name} already exists. Please try again:"
            else
                break
            fi
        done
    fi

    save_account_files "$new_name"
    commit_entry "$new_name" "$hkey" "true"
    set_active "$new_name"
    success "Registered unknown session as '$new_name'."
    return 0
}

cmd_new() {
    # Check if we have exactly 1 argument
    [[ "$#" -le 1 ]] || die "Usage: ${PROG_NAME} new [name]"
    init_deps "wine" "file"
    guard_accounts_file
    init_egs_env
    local new_name="$1" old_name hkey existing ans

    # validate name
    # [[ -n $new_name ]] && { validate_account_name "$new_name" || { warn "Invalid name ${new_name}. Try again" && new_name="" ; } ; }
    if [[ -n "$new_name" ]] && ! validate_account_name "$new_name"; then
        warn "Invalid name: ${new_name}"
        new_name=""
    fi

    # No name prompt
    if [[ -z "$new_name" ]]; then
        while true; do
            read -rp "Enter name for new account: " new_name
            validate_account_name "$new_name" && break
            warn "Invalid account name. Please try again:"
        done
    fi

    old_name=$(active_account)
    hkey=$(get_hkey_id) || debug "Registry key not found. Assuming virgin launcher"

    validate_account_name "$new_name" || die "invalid account name: $new_name"
    account_exists "$new_name" && die "Name already exists"
    kill_egs

    if [[ -n "$hkey" ]]; then
        existing=$(account_by_id "$hkey")
        if [[ -n "$existing" ]]; then
            save_account_files "$existing"
        else
            # Ask user what to do with unknown account
            while true; do
                read -rp "Unrecognised session detected. Claim as '$new_name'? [y/N] " ans
                case "$ans" in
                    y|Y)
                        info "Creating new account: $new_name"
                        handle_unknown_session "$hkey" "$new_name" || die "Aborted. Unable to claim account. Try again"
                        # Terminate here, since the intended goal is complete.
                        exit 0
                        ;;
                    x|X|n|N)
                        warn "Abandoned existing account"
                        break
                        ;;
                    *)
                        warn "Unrecognised input: $ans. Please enter Y or N: "
                        ;;
                esac
            done
        fi
    fi

    [[ -n "$old_name" ]] && set_inactive "$old_name"
    [[ -n "$hkey" ]] && set_hkey_id
    rm -f "${EGS_CONFIG_FILE}"

    success "Launcher cleared. Please login to Epic Games Launcher now"
    while true; do
        read -rp "Done? [y = save / x = abort] " ans
        case "$ans" in
            y|Y)
                info "Creating new account: $new_name"
                cmd_save "$new_name"
                # terminate on job done
                exit 0
                ;;
            x|X|n|N)
                info "Aborted. Attempting to restore account: $old_name"
                kill_egs
                if [[ -n "$old_name" ]]; then
                    cmd_load "$old_name"
                    die "Aborted. Restored ${old_name}"
                else
                    info "No previous account to load. Cleared Epic Games Launcher state"
                    exit 0
                fi
                ;;
            *)
                warn "Unrecognised input: $ans. Please enter Y or X "
                ;;
        esac
    done
}

cmd_save() {
    # Check if we have lte 1 arguments
    [[ "$#" -le 1 ]] || die "Usage: ${PROG_NAME} save [name]"
    init_deps "wine" "file"
    guard_accounts_file
    init_egs_env
    local name="${1:-}" hkey active_name uuid active

    [[ -n "$name" ]] && { validate_account_name "$name" || die "invalid account name: $name" ; }
    hkey=$(get_hkey_id) || die "Epic registry key not found. If this is a fresh install, please log in first."
    [[ -n "$hkey" ]] || die "No Epic account logged in"
    active_name=$(account_by_id "$hkey")

    # No name entered. check active account
    if [[ -z "$name" ]]; then
        info "Name not set. Resolving..."
        if [ -n "$active_name" ]; then
            info "Found existing $active_name"
            name="$active_name"
        else
            info "Unknown account found. Starting wizard..."
            cmd_new
            return # not really needed since this is a handover
        fi
    fi

    # Name entered. Find account name
    if account_exists "$name"; then
        info "Found account. Resolving..."
        uuid=$(account_by_name "$name")
        # Ensure IDs match
        [[ "$uuid" = "$hkey" ]] || die "Account $name exists with different ID"
    else
        info "Account $name not found."
        # Name not found. Check ID
        [[ -z "$active_name" ]] || die "Account already saved under name '$active_name'"
        # name and ID are unique, handover to cmd_new
        info "Unknown account found. Starting wizard..."
        cmd_new "$name"
        return # not really needed since this is a handover
    fi

    # Commit
    active=$(active_account)
    save_account_files "$name"
    [[ -n "$active" ]] && [[ "$active" != "$name" ]] && set_inactive "$active"
    commit_entry "$name" "$hkey" "true"
    success "Saved account: '$name'."
}

cmd_load() {
    # Check if we have exactly 1 argument
    [[ "$#" -eq 1 ]] || die "Usage: ${PROG_NAME} load <name>"
    init_deps "wine" "file"
    guard_accounts_file
    init_egs_env
    local name="$1" uuid hkey active_name ans

    validate_account_name "$name" || die "invalid account name: $name"
    account_exists "$name" || die "Account not found"
    uuid=$(account_by_name "$name")
    hkey=$(get_hkey_id) || die "Epic registry key not found. If this is a fresh install, please log in first."
    kill_egs

    # Check for active account
    if [[ -n "$hkey" ]]; then
        active_name=$(account_by_id "$hkey")
        #check if account is in list
        if account_exists "$active_name"; then
            save_account_files "$active_name"
        else
            # Ask user what to do with unknown account
            while true; do
                read -rp "Unrecognised session detected. Save before proceeding? [y/N] " ans
                case "$ans" in
                    y|Y)
                        info "Starting wizard..."
                        handle_unknown_session "$hkey" || die "Aborted. Unable to claim account. Try again"
                        break
                        ;;
                    x|X|n|N)
                        warn "Abandoned existing account"
                        break
                        ;;
                    *)
                        warn "Unrecognised input: $ans. Please enter Y or N: "
                        ;;
                esac
            done
        fi
    fi

    # Load
    set_hkey_id "$uuid"
    load_account_files "$name"
    set_active "$name"
    success "Loaded account: '$name'. You can now launch your game."
}

cmd_delete() {
    # Check if we have exactly 1 argument
    [[ "$#" -eq 1 ]] || die "Usage: ${PROG_NAME} delete <name>"
    guard_accounts_file
    local name="$1"

    validate_account_name "$name" || die "invalid account name: $name"
    account_exists "$name" || die "Account not found"

    # Check against active
    [[ "$(active_account || true)" != "$name" ]] || die "Cannot delete active account"

    # Delete
    delete_entry "$name"
    rm -rf -- "${PROG_XDG_DIR:?}/${name}"
    success "Deleted account: $name"
}

cmd_rename() {
    # Check if we have exactly 2 arguments
    [[ "$#" -eq 2 ]] || die "Usage: ${PROG_NAME} rename <old_name> <new_name>"
    guard_accounts_file
    local old_name="$1" new_name="$2"

    validate_account_name "$new_name" || die "invalid account name: $new_name"
    validate_account_name "$old_name" || die "invalid account name: $old_name"
    account_exists "$old_name" || die "Source name $old_name not found"
    ! account_exists "$new_name" || die "Target name $new_name already exists"

    # Rename
    mv -- "${PROG_XDG_DIR}/${old_name}" "${PROG_XDG_DIR}/${new_name}"

# TODO: ADD FUNCTIONS delete_entry + commit_entry (with test for *) #
# Leaving atomic sed inplace as it is less prone to DB corruption.  #
# Would require single-use function "edit_entry" to be atomic.      #
# ================================================================= #
    sed -i "s/^\\([*-]\\) $old_name /\\1 $new_name /" "$ACCOUNTS_FILE"
# ================================================================= #
    success "Renamed $old_name to $new_name"
}

cmd_list() {
    guard_accounts_file

    printf "%-8s %-20s %s\n" STATUS NAME ID
    printf "%-8s %-20s %s\n" ------ ---- --
    while read -r mark name id; do
        status=$([ "$mark" = "*" ] && echo ACTIVE || echo "")
        printf "%-8s %-20s %s\n" "$status" "$name" "${id: 0:4}...${id: -4:4}"
    done <"$ACCOUNTS_FILE"
}

cmd_config() {
    [[ $# -le 2 ]] || die "Usage: ${PROG_NAME} config [<key> <value>]. e.g. config pfx \"${HOME}/.wine\""
    guard_config_file
    local key_suffix="${1:-}" value="${2:-}" key_exists=0 key_name

    # If no arguments, print friendly config list
    if [[ $# -lt 1 ]]; then
    info 'Config file (key: value): ' && sed -r 's/^(EGS_)?([^=]+)=/\L\2\E: /' "$CONFIG_FILE"
    return
    fi

    # create key name from suffix
    declare -u "key_name=EGS_${key_suffix}"

    # Test key against config array
    for source_key in "${CONFIG_VARS[@]}"; do
        [[ "$source_key" == "$key_name" ]] && key_exists=1 && break
    done

    # filter for invalid key
    [[ "$key_exists" -eq 1 ]] || die "Invalid key: '$key_suffix'. Valid options: ${CONFIG_VARS[*]}"

    # Prompt user for value if not provided
    if [[ -z "$value" ]]; then
        debug "No value given for key: ${key_name}"
        while true; do
            read -re -p "Enter the new ${key_suffix} value: " value
            case "$key_suffix" in
                # special case for pfx
                "pfx")
                    if ! validate_prefix "$value"; then
                        warn "Invalid path. Please try again:"
                        continue
                    fi
                    ;;
                # everything else
                *)
                    if [[ -z "$value" ]]; then
                        warn "Value cannot be empty. Please try again:"
                        continue
                    fi
                    ;;
            esac
            break
        done
    fi



    # special check for prefix
    [[ "$key_suffix" == "pfx" ]] && { validate_prefix "$value" || die "Invalid prefix: ${value}" ; }

    # set new values
    # declare -g "${key_name}=\"${value}\""
    printf -v "$key_name" '%s' "$value"
    save_config_files "$key_name" "$value"

    success "Successfully updated $key_suffix."
}

cmd_help() {
        cat <<EOF

Commands:
  new <name>            Create a new account with name <name>
                        Example: $PROG_NAME new MyAccount

  save [name]           Save the current account. Optionally specify <name>
                        If specified <name> does not exist, a new account will be created
                        Examples:
                          $PROG_NAME save                 # Save current account using existing active name
                          $PROG_NAME save ExistingAccount # Same as: $PROG_NAME save
                          $PROG_NAME save NewAccount      # Save new account with name NewAccount

  load <name>           Load an existing account by name
                        Example: $PROG_NAME load MyAccount

  delete <name>         Delete an existing account (cannot delete the active account)
                        Example: $PROG_NAME delete MyAccount

  rename <old> <new>    Rename an account from <old> to <new>
                        Example: $PROG_NAME rename OldName NewName

  config                Show all config options
                        Example: $PROG_NAME config

  config <key> [value]  Change a config <key> to [value]. Will prompt for [value] if not specified.
                        Examples:
                          $PROG_NAME config pfx \"$HOME/.wine\"
                          $PROG_NAME config debug 1

  list                  List all saved accounts and the currently active one
                        Example: $PROG_NAME list

EOF
}

cmd_desc(){
    cat <<EOF

EGSwitcher
A tool for swapping Epic Games accounts in the Epic Games Launcher without having to manually logout and login each time. Works on Linux with either WINE or proton.
Copyright (C) 2025 doccy-doc. License: GPL-3.0-only

EOF
}

# =========================
# MAIN
# =========================
CMD="${1:-}"
shift || : # Discard the command name

case "$CMD" in
    new)    cmd_new "$@" ;;
    save)   cmd_save "$@" ;;
    load)   cmd_load "$@" ;;
    delete) cmd_delete "$@" ;;
    rename) cmd_rename "$@" ;;
    config)   cmd_config "$@" ;;
    list)   cmd_list ;;
    -v|--version)
        echo "$VERSION"
        exit 0
    ;;
    -h|--help)
        cmd_desc
        cmd_help
        exit 0
        ;;
    *)
        if [ -n "${CMD}" ] ; then
            warn "Syntax error: command '$CMD' not recognised"
        else
            cmd_desc
        fi
        cmd_help
        exit 1
        ;;
esac
