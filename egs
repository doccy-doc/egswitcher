set -euo pipefail

# =========================
# USER PERMS CHECK
# =========================

[[ $(id -u) -ne 0 ]] || { echo "ERROR: Cannot run as root." >&2; exit 1; }
[[ $(whoami) == "$USER" ]] || { echo "ERROR: User mismatch ($USER vs $(whoami))." >&2; exit 1; }

# =========================
# GLOBAL VARIABLES
# =========================

# PROGRAM
# ========
PROG_NAME=$(basename -- "$0")
PROG_XDG_NAME="egswitcher"
VERSION="1.0.0"

# XDG FILES
# ==========
PROG_XDG_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/${PROG_XDG_NAME}"
PROG_XDG_TMP="${PROG_XDG_CACHE}/tmp"
PROG_XDG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/${PROG_XDG_NAME}"
PROG_XDG_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/${PROG_XDG_NAME}"
ACCOUNTS_FILE="${PROG_XDG_DIR}/accounts.state"
CONFIG_FILE="${PROG_XDG_CONFIG}/${PROG_XDG_NAME}.conf"

# CONFIG VARIABLES
# =================
CONFIG_VARS=("EGS_PFX" "EGS_DEBUG") # CONFIG_FILE

# FIRST-RUN INSTALL
# ==================
#create XDG folders
[[ -d "$PROG_XDG_TMP" ]] || mkdir -p "$PROG_XDG_TMP"
[[ -d "$PROG_XDG_DIR" ]] || mkdir -p "$PROG_XDG_DIR"
[[ -d "$PROG_XDG_CONFIG" ]] || mkdir -p "$PROG_XDG_CONFIG"
#create sourced files
[[ -f "$CONFIG_FILE" ]] || install -m 644 -D <(printf "%s=\n" "${CONFIG_VARS[@]}") "$CONFIG_FILE"
[[ -f "$ACCOUNTS_FILE" ]] || install -m 600 -D /dev/null "$ACCOUNTS_FILE"

# SOURCE CONFIG FILE
# ===================
# shellcheck source=/dev/null
. "${CONFIG_FILE}" # EGS_PFX EGS_DEBUG
# FLAGS
# ======
: "${WINE_INIT:=0}"
: "${EGS_DEBUG:=0}" # CONFIG_FILE

# WINE VARS
# ==========
EGS_REG_KEY='HKCU\Software\Epic Games\Unreal Engine\Identifiers'
EGS_REG_VALUE='AccountId'
# Dynamic defaults
: "${EGS_PFX:="${HOME}/.wine"}" # CONFIG_FILE
: "${WINE_USER:="${USER}"}"
# Envar overrides
EGS_PFX="${EGSPFX:-$EGS_PFX}"
EGS_DEBUG="${EGSDEBUG:-$EGS_DEBUG}"

# PFX FILES
# ==========
INI_FILE="GameUserSettings.ini"
# Dynamic defaults
: "${EGS_USERDIR:="${EGS_PFX}/drive_c/users"}"
: "${EGS_LOCALDATA:="${EGS_USERDIR}/${WINE_USER}/AppData/Local"}"
: "${EGS_APPDATA:="${EGS_LOCALDATA}/EpicGamesLauncher/Saved"}"
: "${EGS_CONFIG_DIR:="${EGS_APPDATA}/Config/WindowsEditor"}"
: "${EGS_CONFIG_FILE:="${EGS_CONFIG_DIR}/${INI_FILE}"}"

# TIMERS
# =======
SHUTDOWN_TIMEOUT=30

# =========================
# MESSAGE HANDLERS
# =========================

die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
warn() { printf 'WARNING: %s\n' "$*" >&2; }
info() { printf 'INFO: %s\n' "$*" >&2; }
success() { printf 'SUCCESS: %s\n' "$*" >&2; }
debug() { [[ "$EGS_DEBUG" = "1" ]] && printf 'DEBUG: ' >&2 && printf '%q ' "$@" >&2 && printf '\n' >&2 || true; }

# =========================
# BOOTSTRAP
# =========================

check_dep() {
    command -v "$1" &>/dev/null || die "Missing dependency: $1 not installed"
}

init_deps() {
    local dep
    for dep in "$@"; do
        case "$dep" in
            wine)
                check_dep "wine"
                check_dep "wineserver"
                check_dep "winedbg"
                ;;
            file)
                check_dep "rsync"
                ;;
            *)
                die "Internal error: Unknown dependency group '$dep'"
                ;;
        esac
    done
}

# trap and delete temp files on exit
trap 'rm -rf "${PROG_XDG_TMP}"' EXIT

# =========================
# VALIDATION
# =========================

sanitise_sed_path() {
    local path="$1"
    path="${path%/}"
    path="${path%\\}"
    # printf '%s\n' "$path" | sed 's/[\\&/'"'"']/\\&/g'
    printf '%s\n' "$path" | sed "s/[\\\\&/'\$\`]/\\\\&/g; s/'/'\\\\\\\''/g"
}

guard_config_file() {
    for var in "${CONFIG_VARS[@]}"; do
         grep -q "^${var}=" "$CONFIG_FILE" || die "Config corrupted: missing $var"
    done
    return 0
}

validate_account_name() {
    local name="$1"
    [[ "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9_-]{0,62}$ ]] || return 1
    return 0
}

guard_accounts_file() {
    local marks names ids

    [[ -s "$ACCOUNTS_FILE" ]] || return 0

    marks=$(grep -c '^\* ' "$ACCOUNTS_FILE" || true)
    [[ "$marks" -le 1 ]] || die "accounts.db corrupted: multiple active (*) entries"

    names=$(awk '{print $2}' "$ACCOUNTS_FILE" | sort | uniq -d || true)
    [[ -z "$names" ]] || die "accounts.db corrupted: duplicate account names"

    ids=$(awk '{print $3}' "$ACCOUNTS_FILE" | sort | uniq -d || true)
    [[ -z "$ids" ]] || die "accounts.db corrupted: duplicate account IDs"

    awk '
        NF==0 {next}
        NF!=3 {exit 1}
        $1!="*" && $1!="-" {exit 1}
    ' "$ACCOUNTS_FILE" || die "accounts.db corrupted: invalid line format"
}

validate_prefix() {
    local new_pfx="${1:-$EGS_PFX}"
    [[ -d "${new_pfx}/drive_c/users" ]] || { debug "Cannot find users directory in path: ${new_pfx}" && return 1 ; }
    return 0
}

# =========================
# INITIALISATION
# =========================

init_egs_env() {
    local wine_user base_dir localdata ans

    # Skip if init already done
    [[ "$WINE_INIT" -eq 1 ]] && return 0

    # Guard against invalid ephemeral override
    [[ -n "${EGSPFX:-}" ]] && { validate_prefix "$EGSPFX" || die "Invalid override prefix: ${EGSPFX}" ; }

    # Validate prefix
    if ! validate_prefix; then
        # Prompt for valid prefix
        while true; do
            read -rp "Would you like to edit the prefix path? [y/N] " ans
            case "$ans" in
                y|Y)
                    # new prefix wizard
                    info "Starting wizard..."
                    prompt_new_prefix
                    break
                    ;;
                x|X|n|N)
                    die "Aborted. Cannot continue without a prefix"
                    ;;
                *)
                    warn "Unrecognised input: $ans. Please enter Y or N "
                    ;;
            esac
        done
    fi

    # Apply the validated prefix state
    export WINEPREFIX="$EGS_PFX"
    export WINEDEBUG="-winediag"
    EGS_USERDIR="${EGS_PFX}/drive_c/users"
    debug "Using WINEPREFIX: $WINEPREFIX"

    # Ask WINE for username
    wine_user="$(wine whoami 2>/dev/null | awk -F "\\" '{print $NF}' | tr -d '\r\n[:space:]')" || true
    if [[ -n "$wine_user" && -d "$EGS_USERDIR/$wine_user" ]]; then
        WINE_USER="$wine_user"
        debug "Detected WINE whoami user: $wine_user"
    else
        # Fallback: check user directories for username
        debug "WINE whoami failed. Using heuristic fallback"
        for dir in "$EGS_USERDIR"/*/; do
            [[ -d "$dir" ]] || continue
            base_dir="$(basename "$dir")"
            [[ "$base_dir" == "Public" || "$base_dir" == "Default" ]] && continue
            WINE_USER="$base_dir"
            debug "Heuristic match found. Using: $base_dir"
            break
        done
    fi

    [[ -n "$WINE_USER" ]] || die "Failed to detect Wine user directory"

    # wine reg query for LOCALAPPDATA
    localdata="$(wine reg query "HKCU\\Volatile Environment" /v LOCALAPPDATA 2>/dev/null | awk -F' ' '/REG_SZ/ {print $NF}' | sed -e 's/\r//g' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')" || true
    [[ -n "$localdata" ]] || die "Registry key for %LOCALAPPDATA% missing"
    debug "Registry LOCALAPPDATA: $localdata"
    EGS_LOCALDATA="$(winepath -u "$localdata")" || die "winepath failed to convert Windows path to Linux path"
    debug "LOCALAPPDATA resolves to: ${EGS_LOCALDATA}"
    EGS_APPDATA="${EGS_LOCALDATA}/EpicGamesLauncher/Saved"
    [[ -d "$EGS_APPDATA" ]] || die "Can not find Epic Games %LOCALAPPDATA% directory. Is your prefix corrupt?"

    # set prefix paths
    EGS_CONFIG_DIR="${EGS_APPDATA}/Config/WindowsEditor"
    EGS_CONFIG_FILE="${EGS_CONFIG_DIR}/${INI_FILE}"

    # flag init complete
    WINE_INIT=1
}

# =========================
# CRUD
# =========================

# READ
# =====
account_by_id() {
    guard_accounts_file
    awk -v id="$1" '$3==id {print $2; exit}' "$ACCOUNTS_FILE"
}

account_by_name() {
    guard_accounts_file
    awk -v n="$1" '$2==n {print $3; exit}' "$ACCOUNTS_FILE"
}

account_exists() {
    guard_accounts_file
    awk -v n="$1" '$2==n {found=1; exit} END {exit found ? 0 : 1}' "$ACCOUNTS_FILE"
}

active_account() {
    guard_accounts_file
    awk '$1=="*" {print $2; exit}' "$ACCOUNTS_FILE"
}

# CREATE
# =======
construct_entry() {
    local name="$1" uuid="$2" active="$3" mark="-"
    [[ "$active" == "true" ]] && mark="*"

    printf "%s %s %s\n" "$mark" "$name" "$uuid"
}

commit_entry() {
    guard_accounts_file
    local name="$1" uuid="$2" active="${3:-true}" tmp="${PROG_XDG_TMP}/accounts-upsert.tmp.$$"  line
    line=$(construct_entry "$name" "$uuid" "$active")

    awk -v n="$name" -v L="$line" '
        BEGIN { found=0 }
        $2 == n { print L; found=1; next }
        { print }
        END { if (!found) print L }
    ' "$ACCOUNTS_FILE" > "$tmp" && mv "$tmp" "$ACCOUNTS_FILE"
}

# UPDATE
# =======
set_inactive() {
    guard_accounts_file
    local name="$1" uuid
    uuid="$(account_by_name "$name")"

    [[ -n "$uuid" ]] || die "Cannot disable non-existent account: '$name'"
    commit_entry "$name" "$uuid" "false"
}

set_active() {
    guard_accounts_file
    local name="$1" uuid old_name
    uuid="$(account_by_name "$name")"
    old_name="$(active_account)"

    [[ -n "$uuid" ]] || die "Cannot activate non-existent account: '$name'"
    [[ -n "$old_name" ]] && set_inactive "$old_name"
    commit_entry "$name" "$uuid" "true"
}

# DELETE
# =======
delete_entry() {
    guard_accounts_file
    local name="$1" tmp="${PROG_XDG_TMP}/accounts-delete.tmp.$$"

    awk -v n="$name" '$2 != n {print}' "$ACCOUNTS_FILE" >"$tmp" || die "Failed to create temp file"
    mv -- "$tmp" "$ACCOUNTS_FILE" || die "Failed to update accounts file"
}

# =========================
# FILE MANIPULATION
# =========================

save_account_files() {
    guard_accounts_file
    init_egs_env
    local name="$1"
    local store="${PROG_XDG_DIR}/${name}"

    debug "Syncing $name from $EGS_CONFIG_FILE to $store"

    mkdir -p "$store"
    [[ -f "$EGS_CONFIG_FILE" ]] || die "No $INI_FILE to save"
    rsync -a "$EGS_CONFIG_FILE" "$store/"
}

load_account_files() {
    guard_accounts_file
    init_egs_env
    local name="$1"
    local store="${PROG_XDG_DIR}/${name}"

    debug "Syncing $name from $store to $EGS_CONFIG_FILE"
    mkdir -p "$EGS_CONFIG_DIR"
    rsync -a "${store}/${INI_FILE}" "$EGS_CONFIG_DIR/"
    debug "Account \"$name\" synced"
}

save_config_files() {
    guard_config_file
    local key="$1" value="$2" san_value
    san_value=$(sanitise_sed_path "$value")

    debug "Updating ${key} to ${value}"
    sed -i "s/^${key}=.*/${key}='${san_value}'/" "$CONFIG_FILE"
    debug "Config ${key} updated"
}

# =========================
# WINE REQUESTS
# =========================

is_egs_running() {
    init_egs_env

    if  winedbg --command "info proc" 2>/dev/null |
        grep -qi 'EpicGamesLauncher\.exe'; then
        debug "winedbg: Epic Games Launcher is running"
        return 0
    else
        debug "winedbg: Epic Games Launcher process not found"
        return 1
    fi
}

kill_egs() {
    init_egs_env
    local tries=15 i
    local delay=$((SHUTDOWN_TIMEOUT / tries))

    # Stage 0: nothing running
    ! is_egs_running && { debug "No Epic Games process found. Skipping kill_egs"; return 0; }

    # Stage 1: attempt graceful shutdown, then recheck
    info "Attempting to close Epic Games. Wait up to ${SHUTDOWN_TIMEOUT}s..."
    wine taskkill /im EpicGamesLauncher.exe /t /f &>/dev/null || true

    printf "Trying" >&2
    for ((i= 1; i<=tries; i++)); do
        sleep "$delay"
        printf "." >&2
        ! is_egs_running && success "Epic Games Closed" && return 0
    done

    # If we get here, it failed to shut down
    # Stage 2: kill wineserver
    printf "\n" >&2
    warn "Epic Games Launcher did not exit after ${SHUTDOWN_TIMEOUT}s."
    info "Force killing wineserver. Wait up to ${SHUTDOWN_TIMEOUT}s..."
    if ! timeout 5 wineserver -w &>/dev/null; then
        debug "wineserver -w timeout reached; firing wineserver -k"
        wineserver -k &>/dev/null || true
    fi

    printf "Trying" >&2
    for ((i=1; i<=tries; i++)); do
        sleep "$delay"
        printf "." >&2
        ! is_egs_running && printf "\n" >&2 && success "Epic Games Closed" && return 0
    done

    printf "\n" >&2
    die "Failed to terminate Epic Games Launcher. Aborted."
}

get_hkey_id() {
    init_egs_env
    local hkey hkey_masked wine_status

    hkey=$(wine reg query "$EGS_REG_KEY" /v "$EGS_REG_VALUE" 2>/dev/null)
    wine_status=$?
    hkey=$(awk '/REG_SZ/ {print $NF}' <<< "$hkey" | tr -d '\r')

    if [[ -n "$hkey" ]]; then
        hkey_masked="${hkey:0:4}****${hkey: -4}"
        debug "Registry $EGS_REG_VALUE: $hkey_masked"
    else
        debug "Could not retrieve hkey from WINE registry"
    fi

    printf '%s' "$hkey"
    return "$wine_status"
}

set_hkey_id() {
    init_egs_env
    local uuid="${1:-}"

    wine reg add "$EGS_REG_KEY" /v "$EGS_REG_VALUE" /t REG_SZ /d "$uuid" /f >/dev/null
}

# =========================
# COMMANDS
# =========================

prompt_new_prefix() {
    local new_pfx

    while true; do
        read -re -p "Enter Wine prefix path: " new_pfx
        if validate_prefix "$new_pfx"; then
            EGS_PFX="$new_pfx"
            save_config_files "EGS_PFX" "$new_pfx"
            return 0
        fi
        warn "Invalid prefix path: ${new_pfx}. Please try again:"
    done
}

